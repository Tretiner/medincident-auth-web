# --- Zitadel API ---
# Base URL self-hosted Zitadel, без trailing slash
ZITADEL_API_URL=https://zitadel.example.com
# Секрет OIDC клиента для NextAuth (≥32 символа)
ZITADEL_SECRET=REPLACE_ME_min_32_chars_use_openssl_rand_base64_32
# Путь к JSON-ключу machine-user (RSA, выгружается в Zitadel консоли)
ZITADEL_MACHINE_KEY_PATH=./secrets/key.json
# Org ID из Zitadel консоли (число)
ZITADEL_ORG_ID=000000000000000000
# Project ID из Zitadel консоли (число) — используется в scope access token'а
ZITADEL_PROJECT_ID=000000000000000000

# --- Zitadel IDP linking (для /api/profile/me/links) ---
# JSON-массив провайдеров. Найти ID в консоли Zitadel → Identity Providers.
# Провайдеры полностью определяются этой переменной — добавить новый = дописать объект.
# Формат: [{"provider":"<key>","id":"<zitadel-idp-id>"}, ...]
ZITADEL_IDPS="[
  { \"provider\": \"telegram\", \"id\": \"000000000000000000\" },
  { \"provider\": \"max\",      \"id\": \"000000000000000000\" }
]"

# --- Application ---
# Публичный URL приложения (https в проде — влияет на Secure cookie flag)
APP_URL=http://localhost:3000
# OIDC client_id зарегистрированного в Zitadel приложения
APP_CLIENT_ID=000000000000000000
# Backend API (MedIncident) — REST
API_URL=http://localhost:8080
# Backend API (MedIncident) — gRPC (host:port)
GRPC_API_URL=localhost:9090

# --- NextAuth.js v5 ---
# openssl rand -base64 32 — используется для подписи JWT cookie
AUTH_SECRET=REPLACE_ME_min_32_chars_use_openssl_rand_base64_32
# URL куда NextAuth редиректит после логина (обычно = APP_URL)
AUTH_URL=http://localhost:3000
# true если за reverse proxy (nginx/traefik/ingress)
AUTH_TRUST_HOST=true
