# --- Stage 1: Install production dependencies only ---
FROM oven/bun:1-alpine AS deps
WORKDIR /app
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile --production || bun install --production

# --- Stage 2: Install all deps + build ---
FROM oven/bun:1-alpine AS builder
WORKDIR /app

COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile || bun install

COPY . .

ARG ZITADEL_API_URL
ARG ZITADEL_SECRET
ARG ZITADEL_MACHINE_KEY_PATH=/app/secrets/key.json
ARG ZITADEL_ORG_ID
ARG ZITADEL_PROJECT_ID
ARG ZITADEL_IDPS
ARG APP_URL
ARG APP_CLIENT_ID
ARG API_URL
ARG GRPC_API_URL
ARG AUTH_SECRET
ARG AUTH_URL
ARG AUTH_TRUST_HOST=true

ENV ZITADEL_API_URL=${ZITADEL_API_URL} \
    ZITADEL_SECRET=${ZITADEL_SECRET} \
    ZITADEL_MACHINE_KEY_PATH=${ZITADEL_MACHINE_KEY_PATH} \
    ZITADEL_ORG_ID=${ZITADEL_ORG_ID} \
    ZITADEL_PROJECT_ID=${ZITADEL_PROJECT_ID} \
    ZITADEL_IDPS=${ZITADEL_IDPS} \
    APP_URL=${APP_URL} \
    APP_CLIENT_ID=${APP_CLIENT_ID} \
    API_URL=${API_URL} \
    GRPC_API_URL=${GRPC_API_URL} \
    AUTH_SECRET=${AUTH_SECRET} \
    AUTH_URL=${AUTH_URL} \
    AUTH_TRUST_HOST=${AUTH_TRUST_HOST}

# --bun = нативный Bun runtime для максимальной ��корости билда
RUN bun --bun run next build

# --- Stage 3: Minimal production runner ---
FROM oven/bun:1-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=deps --chown=nextjs:nodejs /app/node_modules ./node_modules

# Результат билда
COPY --from=builder --chown=nextjs:nodejs /app/.next ./.next
COPY --from=builder --chown=nextjs:nodejs /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/package.json ./
COPY --from=builder --chown=nextjs:nodejs /app/next.config.ts ./

RUN mkdir -p /app/secrets && chown nextjs:nodejs /app/secrets

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["bun", "--bun", "--smol", "run", "next", "start", "-H", "0.0.0.0", "-p", "3000"]
